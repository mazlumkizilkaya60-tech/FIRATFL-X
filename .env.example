# Render veya yerel çalışma için runtime-config değerleri
# Bu dosya sadece örnek içindir, gerçek kimlik bilgileri her zaman gizli tutulmalıdır.

# Genel proxy ayarları
PROXY_MODE=always
BACKEND_BASE_URL=

# Varsayılan kaynak türü: m3u veya xtream
DEFAULT_SOURCE_TYPE=xtream
DEFAULT_SOURCE_LABEL=FIRATFLIX Default IPTV

# M3U kaynağı için:
# DEFAULT_PLAYLIST_URL=https://example.com/playlist.m3u
# DEFAULT_EPG_URL=https://example.com/guide.xml

# Xtream kaynağı için:
DEFAULT_BASE_URL=https://example.com
DEFAULT_USERNAME=your_username
DEFAULT_PASSWORD=your_password
DEFAULT_EPG_URL=https://example.com/guide.xml
