PORT=3000
NODE_ENV=production

# Proxy behavior
FIRATFLIX_PROXY_MODE=always
FIRATFLIX_FORCE_PROXY_IMAGES=true
FIRATFLIX_FORCE_PROXY_STREAMS=true
FIRATFLIX_ALLOWED_AUTH_HOSTS=

# Default source type: xtream | m3u
FIRATFLIX_DEFAULT_SOURCE_TYPE=xtream
FIRATFLIX_DEFAULT_SOURCE_LABEL=FIRATFLIX Default Source

# M3U mode
FIRATFLIX_DEFAULT_PLAYLIST_URL=
FIRATFLIX_DEFAULT_EPG_URL=

# Xtream mode
FIRATFLIX_DEFAULT_BASE_URL=
FIRATFLIX_DEFAULT_USERNAME=
FIRATFLIX_DEFAULT_PASSWORD=
FIRATFLIX_DEFAULT_OUTPUT=m3u8
